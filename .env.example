# Aethene API Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# =============================================================================
# REQUIRED
# =============================================================================

# Convex Database URL (get from Convex dashboard)
CONVEX_URL=https://your-project.convex.cloud

# Gemini API Key (for embeddings)
# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# OpenAI API Key (for GPT-5 mini extraction)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# Memory Extraction Model (gpt-5-mini or gemini-3-flash-preview)
# Default: gpt-5-mini
EXTRACTION_MODEL=gpt-5-mini

# =============================================================================
# SERVER
# =============================================================================

# Port to run the server on
PORT=3006

# Environment (development | production)
NODE_ENV=development

# =============================================================================
# AUTHENTICATION
# =============================================================================

# Static API keys for development (comma-separated)
# In production, use Convex database for key management
API_KEYS=your-dev-api-key-here

# API keys that bypass rate limiting (comma-separated, optional)
UNLIMITED_API_KEYS=

# Optional pepper for hashing API keys stored in Convex
# API_KEY_HASH_PEPPER=

# Required if you want to store connector secrets through /v1/settings or /v3/settings
# Use a long random string and configure the same value anywhere Convex runs
# SETTINGS_ENCRYPTION_KEY=

# =============================================================================
# OPTIONAL - Production Settings
# =============================================================================

# Convex deploy key (for production deployments only)
# CONVEX_DEPLOY_KEY=

# Allowed CORS origins (comma-separated, default: * for development)
# In production, set to your frontend domains
# CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# Enable the expensive /health/deep endpoint in production if you explicitly want it public
# ENABLE_PUBLIC_DEEP_HEALTHCHECK=false

# Log level (debug | info | warn | error)
LOG_LEVEL=info
